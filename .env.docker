# Lumina Docker 本地开发环境配置
# 复制为 .env 后按需修改

# ============================================
# 基础配置
# ============================================

# API 端口映射（默认 8000，如果被占用可改为 8001）
LUMINA_PORT=8000

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# LLM API Keys（必填）
# ============================================

# OpenAI (用于 GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (用于 Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek (推荐，性价比高)
DEEPSEEK_API_KEY=your-deepseek-key-here

# 可选：自定义 DeepSeek API 地址
# DEEPSEEK_API_BASE=https://api.deepseek.com

# ============================================
# 数据库配置（Docker 内使用默认值即可）
# ============================================

# PostgreSQL（Docker 内连接，一般无需修改）
# DATABASE_URL=postgresql://lumina:lumina@postgres:5432/lumina

# Redis（Docker 内连接，一般无需修改）
# REDIS_URL=redis://redis:6379/0

# ============================================
# 开发工具配置
# ============================================

# Windows 下强制文件轮询（解决热加载延迟问题）
WATCHFILES_FORCE_POLLING=true

# 代码自动格式化
AUTO_FORMAT=true

# 测试时显示详细日志
PYTEST_VERBOSE=true

# ============================================
# 功能开关
# ============================================

# 启用 Intent 层调试模式（打印详细识别过程）
INTENT_DEBUG=false

# 启用 RPA 功能（需要浏览器）
RPA_ENABLED=false

# 启用知识库自动更新
KNOWLEDGE_AUTO_UPDATE=true

# ============================================
# 安全配置（生产环境需修改）
# ============================================

# JWT 密钥（生产环境必须修改）
JWT_SECRET=your-secret-key-change-in-production

# 加密密钥（生产环境必须修改）
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ============================================
# OpenClaw 桥接配置（如使用 OpenClaw）
# ============================================

# Python API 地址（OpenClaw 调用时使用）
LUMINA_PYTHON_URL=http://lumina-api:8000

# 禁用意图闸（调试时用）
# LUMINA_DISABLE_INTENT_GATE=1
