# Lumina Python + OpenClaw 桥接
# 复制为 .env 后填写（勿提交 .env）

# Docker Compose 映射端口（可选，默认 8000）
# LUMINA_PORT=8000

# 卷挂载 + Windows 下提高 uvicorn --reload 灵敏度（可选）
# WATCHFILES_FORCE_POLLING=true

# OpenClaw 扩展 → POST /api/v1/marketing/hub
# LUMINA_PYTHON_URL=http://127.0.0.1:8000
# 关闭扩展内 Layer1 意图闸（离题不请求 Python），调试用：在 Gateway 环境设
# LUMINA_DISABLE_INTENT_GATE=1

# LLM（与 infra/config/llm.yaml 中 ${VAR:-} 占位符一致；Docker 通过 env_file 注入）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=

# 本地直接跑 uvicorn 时使用相对路径即可；Docker Compose 会设容器内绝对路径
# LLM_CONFIG_PATH=infra/config/llm.yaml
